PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# Required for admin login smoke tests
E2E_ADMIN_IDENTIFIER=admin
E2E_ADMIN_PASSWORD=passwordadmin

# Optional: valid resident account that has already changed password
E2E_RESIDENT_IDENTIFIER=A-12
E2E_RESIDENT_PASSWORD=your-resident-password

# Required for admin mutation flow: dedicated disposable resident for upload + approval/reject flow
E2E_PAYMENT_RESIDENT_IDENTIFIER=
E2E_PAYMENT_RESIDENT_PASSWORD=

# Required for admin mutation flow: resident house number for cash-paid test
E2E_CASH_RESIDENT_HOUSE_NUMBER=

# Required for settings mutation test on a disposable environment only
E2E_ALLOW_SETTINGS_MUTATION=false

# Optional: disposable resident account for first-login password-change flow
# This test changes the password, so use a dedicated account.
E2E_FIRST_LOGIN_IDENTIFIER=
E2E_FIRST_LOGIN_PASSWORD=password
E2E_FIRST_LOGIN_NEW_PASSWORD=
