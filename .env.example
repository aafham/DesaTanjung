# Public Supabase values. These are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret. Never paste this in chat, commit it, or expose it as NEXT_PUBLIC_*.
# In Vercel, mark this variable as Sensitive and rotate it if it was ever exposed.
SUPABASE_SERVICE_ROLE_KEY=

# Optional fallback values only. Live payment details should normally be managed in Admin Settings.
NEXT_PUBLIC_BANK_ACCOUNT_NAME=Persatuan Penduduk Desa Tanjung
NEXT_PUBLIC_BANK_ACCOUNT_NUMBER=1234567890
NEXT_PUBLIC_BANK_NAME=Maybank
NEXT_PUBLIC_PAYMENT_QR_URL=https://placehold.co/600x600/png?text=Upload+Your+QR
